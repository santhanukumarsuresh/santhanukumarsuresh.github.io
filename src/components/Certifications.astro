---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro:content';

interface Cert {
  name: string;
  level: string;
  url: string;
  badgeUrl: string;
  certificateImage?: ImageMetadata;
}

interface Props {
  certifications: Cert[];
}

const { certifications } = Astro.props;
---

<section id="certifications">
  <div class="container">
    <h2>Certifications</h2>
    <p class="section-intro">Verified React proficiency from Certificates.dev.</p>
    <div class="cert-row">
      {certifications.map((cert) => (
        <a
          class="cert-badge"
          href={cert.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${cert.name} ${cert.level} — view certificate`}
        >
          <img src={cert.badgeUrl} alt={`${cert.name} ${cert.level}`} loading="lazy" />
        </a>
      ))}
    </div>

    {certifications.some((cert) => cert.certificateImage) && (
      <div class="grid cert-showcase">
        {certifications.map((cert) => cert.certificateImage && (
          <a
            class="cert-card"
            href={cert.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${cert.name} ${cert.level} — open verification page`}
          >
            <Image
              src={cert.certificateImage}
              alt={`Certificate of Competence: Certified ${cert.level} React Developer, awarded to Santhanu Kumar S`}
              width={640}
              loading="lazy"
              decoding="async"
            />
            <span class="cert-card-caption">{cert.name} — {cert.level} · view verification</span>
          </a>
        ))}
      </div>
    )}
  </div>
</section>
