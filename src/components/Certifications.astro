---
interface Cert {
  name: string;
  level: string;
  url: string;
}

interface Props {
  certifications: Cert[];
}

const { certifications } = Astro.props;
---

<section id="certifications">
  <div class="container">
    <h2>Certifications</h2>
    <p class="section-intro">Verified React proficiency from Certificates.dev.</p>
    <div class="cert-row">
      {certifications.map((cert) => (
        <a
          class="cert-badge"
          href={cert.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${cert.name} ${cert.level} — view certificate`}
        >
          <span class="cert-badge-label">{cert.name}</span>
          <span class="cert-badge-level">{cert.level}</span>
        </a>
      ))}
    </div>
  </div>
</section>
