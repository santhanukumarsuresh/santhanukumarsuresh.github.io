---
interface ProjectItem {
  title: string;
  description: string;
  impactTag?: string;
}

interface StatItem {
  number: string;
  label: string;
}

interface Props {
  projects: ProjectItem[];
  stats: StatItem[];
}

const { projects, stats } = Astro.props;
---

<section id="projects" class="alt-bg">
  <div class="container">
    <h2>Selected Projects</h2>
    <p class="section-intro">Enterprise platforms and GenAI features I've built end to end.</p>
    <div class="grid projects-grid">
      {projects.map((project) => (
        <div class="card project-card">
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          {project.impactTag && <span class="impact-tag">{project.impactTag}</span>}
        </div>
      ))}
    </div>

    <div class="grid impact-stats">
      {stats.map((stat) => (
        <div class="card stat-card">
          <div class="num">{stat.number}</div>
          <div class="label">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
