---
interface SkillGroup {
  title: string;
  items: string[];
}

interface Props {
  groups: SkillGroup[];
}

const { groups } = Astro.props;
---

<section id="skills" class="alt-bg">
  <div class="container">
    <h2>Technical Stack</h2>
    <p class="section-intro">
      The tools and platforms I use to ship enterprise-grade, production-ready software.
    </p>
    <div class="grid skills-grid">
      {groups.map((group) => (
        <div class="card">
          <h3>{group.title}</h3>
          <p class="skill-items">{group.items.join(', ')}</p>
        </div>
      ))}
    </div>
  </div>
</section>
